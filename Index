function selectIndicator(key) {
  // remove active from all rows
  document.querySelectorAll('.ind-row').forEach(r => r.classList.remove('active'));
  // add active to clicked rows
  document.querySelectorAll(`.ind-row[onclick*="${key}"]`).forEach(r => r.classList.add('active'));
  document.querySelectorAll(`.ind-row[data-key="${key}"]`).forEach(r => r.classList.add('active'));

  const d = IND_DATA[key];
  if (!d) return;

  document.getElementById('ind-panel-default').style.display = 'none';
  document.getElementById('ind-panel-content').style.display = 'block';

  document.getElementById('ind-ph-name').textContent = d.name;
  document.getElementById('ind-ph-formula').textContent = d.formula;
  document.getElementById('ind-pv-value').textContent = d.value;
  document.getElementById('ind-pv-value').style.color = d.color;
  document.getElementById('ind-pv-vs-label').textContent = d.vsLabel;
  document.getElementById('ind-pv-vs-val').textContent = d.vsVal;
  document.getElementById('ind-p-revela').textContent = d.revela;
  document.getElementById('ind-p-impacto').textContent = d.impacto;
  document.getElementById('ind-p-oportu').textContent = d.oportu;

  const tagsEl = document.getElementById('ind-p-tags');
  tagsEl.innerHTML = d.tags.map(t => `<span class="ind-panel-tag ${t.c}">${t.t}</span>`).join('');

  // change panel border color
  document.getElementById('ind-side-panel').style.borderColor = d.color;
  document.getElementById('ind-ph').style.background = `linear-gradient(135deg, ${d.color}CC, ${d.color})`;

  // scroll panel into view on mobile
  document.getElementById('ind-side-panel').scrollIntoView({behavior:'smooth', block:'nearest'});
}

function showTree(type, btn) {
  document.querySelectorAll('.tree-view').forEach(t => t.style.display = 'none');
  document.querySelectorAll('.tree-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tree-' + type).style.display = 'block';
  btn.classList.add('active');
}
