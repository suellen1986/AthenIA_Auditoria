<script>
// ── TAB NAVIGATION ──
function showTab(id) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  const tab = document.getElementById(id);
  if (tab) tab.classList.add('active');
  if (event && event.currentTarget) event.currentTarget.classList.add('active');
}

// ── SCORE AREA NAV ──
function showTabById(id) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  const tab = document.getElementById(id);
  if (tab) tab.classList.add('active');
  const btn = document.querySelector(`.tab-btn[onclick*="${id}"]`);
  if (btn) btn.classList.add('active');
}

// ── FILTER CHIPS ──
const activeFilters = new Set(['critical','high','medium','low','opportunity']);

function toggleFilter(el, type) {
  if (activeFilters.has(type)) {
    activeFilters.delete(type);
    el.classList.remove('active');
  } else {
    activeFilters.add(type);
    el.classList.add('active');
  }
  applyFilters();
}

function filterDimension(val) {
  document.querySelectorAll('#main-risk-table tbody tr').forEach(row => {
    const dim = row.getAttribute('data-dim');
    const sev = row.getAttribute('data-severity');
    const dimOk = (val === 'all') || (dim === val);
    const sevOk = activeFilters.has(sev);
    row.style.display = (dimOk && sevOk) ? '' : 'none';
  });
}

function applyFilters() {
  const dimSel = document.querySelector('.filter-select');
  const dimVal = dimSel ? dimSel.value : 'all';
  filterDimension(dimVal);
}

// ── PAA FILTERS ──
const paaPrios = new Set(['P1','P2','P3','P4']);

function applyPAAFilters() {
  const area = document.getElementById('paa-area-filter') ? document.getElementById('paa-area-filter').value : 'all';
  const coso = document.getElementById('paa-coso-filter') ? document.getElementById('paa-coso-filter').value : 'all';
  document.querySelectorAll('#paa-tbody tr').forEach(row => {
    const ra = row.getAttribute('data-area') || '';
    const rc = row.getAttribute('data-coso') || '';
    const rp = row.getAttribute('data-prio') || '';
    const aOk = (area === 'all') || (ra === area);
    const cOk = (coso === 'all') || (rc === coso);
    const pOk = paaPrios.has(rp);
    row.style.display = (aOk && cOk && pOk) ? '' : 'none';
  });
}

function togglePAAPrio(el, prio) {
  if (paaPrios.has(prio)) {
    paaPrios.delete(prio);
    el.classList.remove('active');
  } else {
    paaPrios.add(prio);
    el.classList.add('active');
  }
  applyPAAFilters();
}

function exportPAACSV() {
  const rows = [['ID','Tema','Área Auditada','Prioridade','COSO','IIA','Score','Evidência 1T26/PN']];
  document.querySelectorAll('#paa-tbody tr').forEach(row => {
    if (row.style.display === 'none') return;
    const cells = row.querySelectorAll('td');
    if (!cells.length) return;
    const id = cells[1] ? cells[1].innerText.trim() : '';
    const tema = cells[2] ? cells[2].innerText.replace(/\n/g,' ').trim() : '';
    const area = cells[3] ? cells[3].innerText.trim() : '';
    const prio = row.getAttribute('data-prio') || '';
    const coso = cells[4] ? cells[4].innerText.trim() : '';
    const iia = cells[5] ? cells[5].innerText.trim() : '';
    const evid = cells[6] ? cells[6].innerText.trim() : '';
    const score = cells[7] ? cells[7].innerText.trim() : '';
    rows.push([id, tema, area, prio, coso, iia, score, evid]);
  });
  const csv = rows.map(r => r.map(c => `"${(c||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'ATHENIA_PAA_2026_1T26.csv'; a.click();
  URL.revokeObjectURL(url);
}

