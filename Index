<script>
// ── SIMULADOR DE CENÁRIOS ──
const BASE = {
  receita_anual: 494744,   // R$ MM (1T26 × 4)
  cpv_anual: 256336,       // CPV base
  opex_anual: 80600,       // Despesas operacionais anualizadas
  da_anual: 86456,         // D&A
  capital_investido: 799449,
  wacc: 0.118,
  brent_base: 80.61,  // Brent médio real 1T26 — Excel Tabela 1
  fx_base: 5.26,      // Dólar médio real 1T26 — Excel Tabela 1
  prod_base: 3225,
  ie_base: 22000,          // R$ MM
  sens_brent: 2000,        // R$ MM por US$1 de variação no Brent (anualizado)
  sens_fx: 12000,          // R$ MM por R$0,50 de variação cambial no FCO
};

function calcScenario(brent, fx, ie, opexPct, prod) {
  // Receita ajustada pelo Brent e produção
  const brentVar = (brent - BASE.brent_base) * BASE.sens_brent;
  const prodVar  = (prod - BASE.prod_base) / 100 * 8000;
  const rec = BASE.receita_anual + brentVar + prodVar;

  // CPV ajustado pelo Bex e FX
  const fxImpactCPV = (fx - BASE.fx_base) / 0.5 * 6000;
  const cpv = BASE.cpv_anual + fxImpactCPV;

  // OPEX
  const opex = BASE.opex_anual * (1 + opexPct / 100);

  // EBIT
  const ebit = rec - cpv - opex;

  // Resultado financeiro líquido estimado (simplificado)
  const rfin = 7866 * 4; // base

  // EBT
  const ebt = ebit + rfin;

  // Tributos (ETR 33.3%)
  const trib = ebt * 0.333;

  // Lucro líquido
  let ll = ebt - trib;

  // IE impacto direto no caixa (não na DRE — já no FCO)
  // FCO base - variação FCO
  const fxImpactFCO = -(fx - BASE.fx_base) / 0.5 * BASE.sens_fx;
  const fco = (43975 * 4) + brentVar + fxImpactFCO + prodVar * 0.5 - ie + BASE.ie_base;

  // NOPAT e ROIC
  const nopat = ebit * 0.667 - (ie - BASE.ie_base) * 0.667;
  const roic = (nopat / BASE.capital_investido) * 100;
  const spread = roic - BASE.wacc * 100;
  const eva = spread / 100 * BASE.capital_investido;

  // Margem líquida
  const mgLiq = ll > 0 ? (ll / rec * 100) : 0;

  // Brent de equilíbrio
  const breakeven = Math.round(BASE.brent_base - (fco - 141500) / BASE.sens_brent);

  return { rec, ll, fco, roic, spread, eva, mgLiq, breakeven };
}

function formatBi(v) {
  const abs = Math.abs(v);
  const sign = v < 0 ? '−' : '+';
  if (abs >= 1000) return (v < 0 ? '−' : '') + 'R$' + (abs/1000).toFixed(0) + ' bi';
  return sign + 'R$' + abs.toFixed(0) + ' mi';
}

function getZone(roic, spread, fco) {
  if (roic >= 15 && spread >= 3) return {color:'var(--risk-low)', bg:'#E8F8EE', label:'✅ ZONA VERDE — Empresa cria valor com spread sólido'};
  if (roic >= 12 && spread >= 0) return {color:'#8A6900', bg:'#FFFBEA', label:'🟡 ZONA AMARELA — Valor criado mas spread estreito. Monitorar.'};
  if (roic >= 10 && spread >= -2) return {color:'var(--risk-high)', bg:'#FFF0E6', label:'🟠 ZONA DE ALERTA — EVA negativo. FCO pressiona obrigações.'};
  return {color:'var(--risk-critical)', bg:'#FDECEA', label:'🔴 ZONA CRÍTICA — Destruição de valor. FCO insuficiente. Revisar PN.'};
}

function updateSim() {
  const brent = +document.getElementById('sl-brent').value;
  const fx    = +document.getElementById('sl-fx').value;
  const ie    = +document.getElementById('sl-ie').value * 1000;
  const opex  = +document.getElementById('sl-opex').value;
  const prod  = +document.getElementById('sl-prod').value;

  document.getElementById('sv-brent').textContent = 'US$' + brent;
  document.getElementById('sv-fx').textContent = 'R$' + fx.toFixed(2);
  document.getElementById('sv-ie').textContent = ie > 0 ? 'R$' + (ie/1000).toFixed(0) + ' bi/a' : 'R$0 (sem IE)';
  document.getElementById('sv-opex').textContent = (opex >= 0 ? '+' : '') + opex + '%';
  document.getElementById('sv-prod').textContent = prod.toLocaleString('pt-BR');

  const r = calcScenario(brent, fx, ie, opex, prod);
  const zone = getZone(r.roic, r.spread, r.fco);

  document.getElementById('sim-rec').textContent = 'R$' + Math.round(r.rec/1000) + ' bi';
  document.getElementById('sim-ll').textContent  = 'R$' + Math.round(r.ll/1000) + ' bi';
  document.getElementById('sim-fco').textContent = 'R$' + Math.round(r.fco/1000) + ' bi';
  document.getElementById('sim-fco').style.color = zone.color;
  document.getElementById('sim-mg').textContent  = r.mgLiq.toFixed(1) + '%';
  document.getElementById('sim-mg').style.color  = zone.color;
  document.getElementById('sim-roic').textContent = r.roic.toFixed(1) + '%';
  document.getElementById('sim-roic').style.color  = zone.color;
  document.getElementById('sim-eva').textContent  = formatBi(r.eva);
  document.getElementById('sim-eva').style.color   = r.eva >= 0 ? 'var(--risk-low)' : 'var(--risk-critical)';
